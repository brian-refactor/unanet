# Credentials & tokens — never commit
etl/.env
etl/ajera.env
etl/qbo_tokens.json
etl/*.qwc

# Python cache
etl/__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Large source-data files (QB Desktop exports, Ajera XLS, migration templates)
Documentation/
TimeReport/
input/
# All output files ignored by default — generated CSVs are added explicitly via git add
output/

# Excel lock files
~$*

# Local Claude session data
.claude/

# Streamlit local secrets (use Streamlit Cloud secrets UI for prod)
.streamlit/secrets.toml
